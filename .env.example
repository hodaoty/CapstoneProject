SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=duyenptmse184526@fpt.edu.vn
SMTP_PASSWORD=your_app_password_here

# Telegram Bot notification
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
# FIREWALL_ADMIN_URL: dia chi public cua firewall-admin service, dung cho inline button
# Vi du: http://192.168.1.100:9000 (IP may chay Docker, khong phai localhost)
FIREWALL_ADMIN_URL=http://YOUR_HOST_IP:9000

# === HUONG DAN TAO TELEGRAM BOT ===
# 1. Mo Telegram, tim @BotFather, gui /newbot
# 2. Dat ten bot (vi du: FirewallAlertBot), lay TOKEN (dang 123456:ABC-DEF...)
# 3. Gui bat ky tin nhan nao den bot vua tao
# 4. Mo URL sau de lay CHAT_ID:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    Tim truong "id" trong "chat" object
# 5. De webhook nhan callback button, sau khi deploy chay lenh:
#    curl -X POST https://api.telegram.org/bot<TOKEN>/setWebhook \
#         -d url=http://YOUR_HOST_IP:9000/telegram/webhook
# =====================================
